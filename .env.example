# Groq (free at console.groq.com) — used as judge and default target
GROQ_API_KEY=your_groq_api_key_here

# OpenAI — required only when --provider openai
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic — required only when --provider anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Target model to attack
TARGET_PROVIDER=groq
TARGET_MODEL=llama-3.1-8b-instant

# Judge model — should be smarter than the target
JUDGE_MODEL=llama-3.3-70b-versatile

# Max mutation retries per attack before moving on
MAX_RETRIES=2
